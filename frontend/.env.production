# ─── Mero Luck Frontend — Production Environment Variables ────────────────────
# These are baked into the static build at build time (Next.js).
# Update these values with your actual EC2 IP/domain BEFORE running `npm run build`.

# Your EC2 public IP or domain — NO trailing slash
# Format: http://YOUR_EC2_PUBLIC_IP  (or https://yourdomain.com if you add SSL later)
NEXT_PUBLIC_API_URL=http://YOUR_EC2_PUBLIC_IP/api
NEXT_PUBLIC_SOCKET_URL=http://YOUR_EC2_PUBLIC_IP
