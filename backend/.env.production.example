# ─── Mero Luck Backend — Production Environment Variables ─────────────────────
# Copy this file to .env on your EC2 instance and fill in all values.
# NEVER commit the real .env to version control.

# ─── SERVER ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── DATABASE (Neon PostgreSQL) ───────────────────────────────────────────────
# Get this from your Neon dashboard → Connection Details → Connection string
DATABASE_URL="postgresql://meroluck_owner:PASSWORD@ep-XXXX.ap-southeast-1.aws.neon.tech/meroluck?sslmode=require"

# ─── JWT SECRETS ──────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_HEX_STRING

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your CloudFront URL — fill this AFTER CloudFront is created (Phase 2)
FRONTEND_URL=https://XXXXXXXXXXXX.cloudfront.net

# ─── EMAIL (Gmail SMTP) ───────────────────────────────────────────────────────
# See: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password-no-spaces
SMTP_FROM="Mero Luck" <your-gmail@gmail.com>
